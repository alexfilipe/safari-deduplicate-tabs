{
  "manifest_version": 2,
  "name": "Safari Deduplicate Tabs",
  "version": "1.0.0",
  "description": "Find duplicate tabs in the current Safari window and close all but one for each URL.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png",
    "512": "icons/icon-512.png"
  },
  "permissions": [
    "tabs"
  ],
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "64": "icons/icon-64.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Deduplicate Tabs",
    "default_popup": "popup.html"
  }
}
